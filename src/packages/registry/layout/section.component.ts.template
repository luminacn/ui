import { Directive, Input, HostBinding } from '@angular/core';
import { cn } from '../../../lib/cn';

@Directive({
  selector: 'section[luminaSection]', // Targets <section luminaSection>
  standalone: true,
})
export class LuminaSectionDirective {
  @Input('class') userClass = '';

  @HostBinding('class')
  get computedClass() {
    return cn(
      'py-12 md:py-16 lg:py-24', // Standard vertical padding scale
      this.userClass,
    );
  }
}
