import { Directive, Input, ElementRef, inject } from "@angular/core";
import { cn } from "../../../lib/cn";

@Directive({
  selector: "[luminaInputIcon]",
  standalone: true,
  host: {
    "[class]": "classes",
  },
})
export class LuminaInputIconDirective {
  @Input() side: "start" | "end" = "start";

  get classes() {
    return cn(
      "absolute h-4 w-4 text-muted-foreground top-1/2 -translate-y-1/2", // Centering logic
      this.side === 'start' ? "left-3" : "right-3"
    );
  }
}
